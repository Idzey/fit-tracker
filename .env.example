# Docker Compose variable substitution
# Copy to .env and fill in values

DB_PASSWORD=secret
JWT_SECRET=change-this-to-random-32-char-string
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=fittrack
R2_FORCE_PATH_STYLE=true
REVENUECAT_WEBHOOK_SECRET=
YOOMONEY_SECRET=
YOOMONEY_WALLET=
PRO_MONTHLY_PRICE=990
PAYMENT_SUCCESS_URL=fittrack://payment-success
SENTRY_DSN=
SENTRY_RELEASE=fittrack-local
SENTRY_TRACES_SAMPLE_RATE=0.1

# Frontend (Expo)
EXPO_PUBLIC_API_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:8082
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
